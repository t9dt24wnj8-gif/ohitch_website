---
import BaseLayout from '../layouts/BaseLayout.astro'

import spt70Hero from '../assets/images/SPT-70_EKB_Fakel.png'
import gaussSection from '../assets/images/gauss.png'
import ritSection from '../assets/images/rit.png'
import xjetSection from '../assets/images/xjet.png'
import acftSection from '../assets/images/acft.png'

import gaussVideoMobile from '../assets/videos/GAUSS_mobile.mp4'
import gaussVideoDesktop from '../assets/videos/GAUSS_desktop.mp4'

const title = 'EP Video Archive — Oliver Hitchens'
const description = 'An archive of electric propulsion hot-fire videos and on-orbit firings.'
---

<BaseLayout title={title} description={description}>

  <div class="full-bleed-hero compact-hero gauss-hero">
    <video
      id="gauss-boomerang"
      data-mobile-src={gaussVideoMobile}
      data-desktop-src={gaussVideoDesktop}
      autoplay
      muted
      playsinline
      preload="metadata"
      loop
    >
      <source id="gauss-source" src={gaussVideoDesktop} type="video/mp4" />
    </video>

    <script type="module">
      const video = document.getElementById('gauss-boomerang');
      const source = document.getElementById('gauss-source');

      const mobileSrc = video.dataset.mobileSrc;
      const desktopSrc = video.dataset.desktopSrc;

      const isMobile = window.matchMedia('(max-width: 768px)').matches;

      source.src = isMobile ? mobileSrc : desktopSrc;

      video.load();
      video.play().catch(() => {});
    </script>

    <h1 style="color:#fff;font-size:clamp(2.4rem,5vw,4.2rem);margin:0;text-align:center;text-shadow:0 8px 30px rgba(0,0,0,0.6)">
      Electric Propulsion Video Archive
    </h1>
  </div>

  <main class="container page-content ep-video-archive">
    <article>
      <br/><br/>
      <p>Electric propulsion hot-fire videos are surprisingly difficult to find, especially in-space footage, and many are at risk of being lost over time. This archive was created to preserve and bring them together in one place.</p>
      <p>Enjoy the <a href="https://www.youtube.com/watch?v=1t2O-46VqZQ">glow</a>!</p>
      <br/><br/>
      <p style="font-style:italic;font-size:0.95rem">If you know of a thruster that is missing from this archive and there is a video of it, please submit it <a href="https://forms.gle/du9L1MmwG3nSDotUA">here</a>.</p>

      <br/><br/>
      <!-- IN-SPACE HOT FIRES -->
      <div class="accordion">
        <button class="accordion-toggle" aria-expanded="false">
          <div class="section-hero" style={`background-image: url(${spt70Hero.src})`}>
              <h2>IN-SPACE <span class="break-mobile"></span>HOT FIRES</h2>
            </div>
        </button>
        <div class="accordion-content">
          <section class="media-row">
            <div class="media-text">
              <h3>JW-200 Hall Effect Thruster (Hongqing Technology)</h3>
              <p>On-orbit ignition video of the JW-200 hall thruster on the Honghu satellite. (2x speed)</p>
<p class="small-italic">Propellant: krypton</p>
<p class="small-italic"><a href="https://www.hongqing.tech/en/business/core-products#zaiguixinxi">more info</a> • <a href="https://mp.weixin.qq.com/s/pBSlDdXh1TyMwQ03oIy_4Q">Video source</a></p></div>
            <div class="media-video">
              <div class="youtube-player" data-id="bicO3Ctk6U0" data-title="JW-200 on-orbit"></div>
            </div>
          </section>

          <section class="media-row">
            <div class="media-text">
              <h3>SPT-70 Hall Effect Thruster (EKB Fakel)</h3>
              <p>On-orbit ignition video of two SPT-70 hall thrusters on the EgyptSat A satellite.</p>
<p class="small-italic">Propellant: xenon</p>
<p class="small-italic"><a href="https://space.skyrocket.de/doc_sdat/egyptsat-a.htm">more info</a> • <a href="https://youtu.be/5hfUoVh9FWs?si=tzIRpKCQweDlQUur&t=66">Video source</a></p></div>
            <div class="media-video">
              <div class="youtube-player" data-id="LwS3wG9IQrk" data-title="SPT-70 on-orbit"></div>
            </div>
          </section>

          <section class="media-row">
            <div class="media-text">
              <h3>SPS 25 Hall Effect Thruster (SETS)</h3>
              <p>On-orbit video of the SPS 25 hall thruster on the EOS SAT-1 satellite.</p>
<p class="small-italic"><a href="https://x.com/sets_space/status/1734127219453133261">Video source</a> • <a href="https://sets.space/sps25/">Thruster info</a></p></div>
            <div class="media-video">
              <div class="youtube-player" data-id="KF8lbApuPkc" data-title="SPS 25 on-orbit"></div>
            </div>
          </section>

          <section class="media-row">
            <div class="media-text">
              <h3>Spaceware Micro Hall Effect Thrusters (EXOTRAIL)</h3>
              <p>On-orbit video of two Spaceware micro thrusters on the spacevan-001 satellite.</p>
<p class="small-italic">Propellant: xenon</p>
<p class="small-italic"><a href="https://www.linkedin.com/posts/spacevan-spaceware-spacevan-share-7203772119288004608-_OX-/">Video source</a> • <a href="https://www.exotrail.com/product/hall-thrusters-spaceware">Thruster info</a></p></div>
            <div class="media-video">
              <div class="youtube-player" data-id="bAp8aOZ7rRQ" data-title="Spaceware micro thrusters"></div>
            </div>
          </section>
        </div>
      </div>

